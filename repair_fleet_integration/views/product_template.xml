<odoo>
    <record id="view_product_template_vehicle_form" model="ir.ui.view">
        <field name="name">canas.product.template.vehicle.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="vehicle_id" string="Vehicle Fleet"/>
                <field name="equipment_code_required"/>
            </xpath>
        </field>
    </record>
</odoo>
