        <field name="name">Equipment Codes</field>
        <field name="res_model">equipment.code</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="equipment_code_tree_view" parent="fleet.fleet_configuration"
              action="equipment_code_action" sequence="404"/>
