<odoo>
    <record id="timesheet_view_tree_fleet_vehicle" model="ir.ui.view">
        <field name="name">account.analytic.line.view.tree.with.fleet.vehicle</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_tree"/>
        <field name="mode">primary</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="fleet_vehicle_id" required="1" options='{"no_open": True}'/>
            </xpath>
        </field>
    </record>

    <record id="timesheet_view_grid_by_fleet_vehicle" model="ir.ui.view">
        <field name="name">account.analytic.line.grid.fleet.vehicle</field>
        <field name="model">account.analytic.line</field>
        <field name="arch" type="xml">
            <grid string="Timesheets" adjustment="object" adjust_name="adjust_grid">
                <field name="fleet_vehicle_id" type="row" section="1"/>
                <field name="date" type="col">
                    <range name="week" string="Week" span="week" step="day"/>
                    <range name="month" string="Month" span="month" step="day"/>
                </field>
                <field name="unit_amount" type="measure" widget="timesheet_uom"/>
            </grid>
        </field>
    </record>

    <record id="fleet_vehicle_timesheet_view_search" model="ir.ui.view">
        <field name="name">account.analytic.line.search</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='date']" position="before">
                <field name="fleet_vehicle_id"/>
            </xpath>
            <xpath expr="//search/group/filter[@name='groupby_employee']" position="before">
                 <filter string="Fleet Vehicle" name="groupby_fleet" domain="[]" context="{'group_by':'fleet_vehicle_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="act_hr_timesheet_line_by_vehicle" model="ir.actions.act_window">
        <field name="name">By Fleet Vehicle</field>
        <field name="res_model">account.analytic.line</field>
        <field name="view_ids"
               eval="[(5, 0, 0),
                      (0, 0, {'view_mode': 'grid', 'view_id': ref('timesheet_view_grid_by_fleet_vehicle')}),
                      (0, 0, {'view_mode': 'tree', 'view_id': ref('timesheet_view_tree_fleet_vehicle')})]"/>
        <field name="view_mode">grid,tree,form</field>
        <field name="domain">[('project_id', '!=', False), ('fleet_vehicle_id', '!=', False)]</field>
        <field name="search_view_id" ref="fleet_vehicle_timesheet_view_search"/>
        <field name="context">{'search_default_groupby_fleet': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a new activity
            </p><p>
            You can register and track your workings hours by project every
            day. Every time spent on a project will become a cost and can be re-invoiced to
            customers if required.
        </p>
        </field>
    </record>

    <record id="hr_timesheet.act_hr_timesheet_report" model="ir.actions.act_window">
        <field name="domain">[('project_id', '!=', False), ('fleet_vehicle_id', '=', False)]</field>
    </record>

    <menuitem id="timesheet_menu_grid_by_vehicle"
              name="By Fleet Vehicle"
              parent="hr_timesheet.menu_timesheets_reports_timesheet"
              action="act_hr_timesheet_line_by_vehicle"
              sequence="16"/>
</odoo>
