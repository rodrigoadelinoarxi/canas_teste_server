<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_invoice_account_cancel_reason" inherit_id="account.report_invoice_document" priority="102">
        <xpath expr="//div[@id='informations']" position="after">
            <p t-if="o.move_type == 'out_refund' or o.state == 'cancel'">Reason:
                <span t-field="o.reason"/>
            </p>
        </xpath>
    </template>
</odoo>
