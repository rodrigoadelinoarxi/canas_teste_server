<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--View, action and action view for Invoices-->
    <record id="account_cancel_wizard_view_form_invoice" model="ir.ui.view">
        <field name="name">account.cancel.wizard.view.form.invoice</field>
        <field name="model">account.cancel.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="cancel_move" string="Confirm" type="object" class="oe_highlight"/>
                    <button string="Close" special="cancel" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="account_cancel_wizard_action_invoice" model="ir.actions.act_window">
        <field name="name">Account Cancel Wizard</field>
        <field name="res_model">account.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="account_cancel_wizard_action_invoice_form" model="ir.actions.act_window.view">
        <field name="view_mode">form</field>
        <field name="view_id" ref="account_cancel_wizard_view_form_invoice"/>
        <field name="act_window_id" ref="account_cancel_wizard_action_invoice"/>
    </record>

    <!--View, action and action view for Payments-->
    <record id="account_cancel_wizard_view_form_payment" model="ir.ui.view">
        <field name="name">account.cancel.wizard.view.form.payment</field>
        <field name="model">account.cancel.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="cancel_payment" string="Confirm" type="object" class="oe_highlight"/>
                    <button string="Close" special="cancel" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="account_cancel_wizard_action_payment" model="ir.actions.act_window">
        <field name="name">Account Cancel Wizard</field>
        <field name="res_model">account.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="account_cancel_wizard_action_payment_form" model="ir.actions.act_window.view">
        <field name="view_mode">form</field>
        <field name="view_id" ref="account_cancel_wizard_view_form_payment"/>
        <field name="act_window_id" ref="account_cancel_wizard_action_payment"/>
    </record>
</odoo>
