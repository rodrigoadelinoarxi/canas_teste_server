<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form.inherit.account_cancel_reason</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='button_cancel'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='button_cancel']" position="after">
                <button name="%(account_cancel_wizard_action_invoice)d"
                        type="action"
                        states="posted"
                        string="Cancel Entry"
                        groups="account.group_account_invoice"/>
            </xpath>
            <xpath expr="//group[@name='sale_info_group']/field[@name='ref']" position="after">
                <field name="reason"/>
            </xpath>
        </field>
    </record>
</odoo>
