<odoo>
    <template id="discount_report_purchaseorder_document" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//table/thead/tr/th[last()]" position="before">
            <th id="th_first_discount" class="text-right" style="width:100px;">
                <strong>1º Discount</strong>
            </th>
            <th id="th_second_discount" class="text-right" style="width:100px;">
                <strong>2º Discount</strong>
            </th>
        </xpath>

        <xpath expr="//table/tbody//tr/t[@t-if='not line.display_type']/td[last()]" position="before">
            <td id="td_first_discount" class="text-right" style="width:100px;">
                <span t-field="line.first_discount"/>
            </td>
            <td id="td_second_discount" class="text-right" style="width:100px;">
                <span t-field="line.second_discount"/>
            </td>

        </xpath>
    </template>
</odoo>
