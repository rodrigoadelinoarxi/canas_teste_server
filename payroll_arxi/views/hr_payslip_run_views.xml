<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Payment button on the payslip run form. -->
    <record id="hr_payslip_run_view_form_warning" model="ir.ui.view">
        <field name="name">hr.payslip.run.inherit.form</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='name']" position="before">
                <div class="alert alert-warning" role="alert" attrs="{'invisible': [('warning_message','=',False)]}">
                    <field name="warning_message"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>








