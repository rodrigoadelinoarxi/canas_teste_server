<odoo>
    <record id="allowance_line_treeview" model="ir.ui.view">
        <field name="name">Allowance Lines</field>
        <field name="model">allowance.line</field>
        <field name="arch" type="xml">
            <tree create="0" editable="bottom">
                <field name="salary_structure_type_ids" widget="many2many_tags"/>
                <field name="date"/>
                <field name="food_allowance_value"/>
                <field name="transport_allowance_value"/>
                <field name="updated" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="allowance_line_treeview_action" model="ir.actions.act_window">
        <field name="name">Allowance Lines</field>
        <field name="res_model">allowance.line</field>
        <field name="view_mode">tree</field>
        <field name="target">current</field>
    </record>

    <menuitem action="allowance_line_treeview_action"
              id="menu_item_allowance_line"
              groups="base.group_no_one"
              parent="hr_payroll.menu_hr_salary_configuration"
              sequence="41" name="Allowance Lines Update"/>
</odoo>
