<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model='ir.ui.view' id = "timesheet_line_import_wizard_id">
        <field name="name">import.timesheet.line.wizard</field>
        <field name="model">import.timesheet.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Timesheet Line">
                <separator string="This wizard will import timesheet lines from the selected excel file. Please make sure you have selected .xls/xlsx excel files"/>
                <group>
                    <field name="files" filename="datas_fname" required="True"/>
                    <field name="datas_fname" invisible="1"/>
                </group>
                <group col="5" invisible="context.get('model') == 'project.task'">
                    <field name="project_id" required="context.get('model') != 'project.task'" options="{'no_create': True}"/>
                    <field name="task_id" domain="[('project_id', '=', project_id)]" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button string="Import Timesheet Lines" name="timesheet_file" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="task_line_import_wizard_action">
        <field name="name">Import Task Timesheet Lines</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">import.timesheet.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'model': 'project.task', 'default_task_id': active_id}</field>
    </record>

    <record model="ir.actions.act_window" id="timesheet_line_import_wizard_action">
        <field name="name">Import Timesheet Lines</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">import.timesheet.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'model': 'account.analytic.line'}</field>
    </record>
</odoo>
