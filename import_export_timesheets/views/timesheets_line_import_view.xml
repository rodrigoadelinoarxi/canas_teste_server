<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="project_task_form_view_id_inherit">
        <field name="name">project.task.form.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_create_shipyard']" position="after">
                <button name="%(task_line_import_wizard_action)d" type="action" string="Import Timesheet Lines"
                        class="btn-primary" context="{'default_project_id': project_id}"/>
            </xpath>
        </field>
    </record>

    <record id="timesheet_view_search_import_export_override" model="ir.ui.view">
        <field name="name">timesheet.view.search.import.export.override</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='groupby_employee']" position="before">
                <filter string="Mozambique" name="mozambique" domain="[('tag_ids', 'ilike', 'Mozambique')]"/>
                <filter string="Overseas" name="overseas" domain="[('tag_ids', 'ilike', 'Overseas')]"/>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_timesheet_import" parent="hr_timesheet.menu_hr_time_tracking"
              action="import_export_timesheets.timesheet_line_import_wizard_action" sequence="404"/>
</odoo>
