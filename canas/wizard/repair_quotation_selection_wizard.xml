<odoo>
    <record id="repair_quotation_selection_wizard_form" model="ir.ui.view">
        <field name="name">repair.quotation.selection.wizard.form</field>
        <field name="model">repair.quotation.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Form" create="false" edit="false">
                <separator string="Select parts or operations for quotation creation"/>
                <group>
                    <field name="state" widget="radio"/>
                </group>
                <footer>
                    <button name="generate_purchase_order" string="Create Quotation" type="object" class="btn-primary"/>
                    <button special="cancel" string="Cancel" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
