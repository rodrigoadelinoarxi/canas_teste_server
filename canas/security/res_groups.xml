<odoo noupdate="0">
    <record id="logistica_pt" model="res.groups">
        <field name="name">Logistica_PT</field>
    </record>

    <record id="group_purchase_access_followed_projects" model="res.groups">
        <field name="name">Purchase: Access to Followed Projects Only</field>
    </record>

    <record id="group_group_purchase_access_own_documents_followed_projects" model="res.groups">
        <field name="name">Purchase: Access to Own Documents and Followed Projects</field>
    </record>

    <record model="ir.rule" id="ir_project_followers_only_purchase_rule">
        <field name="name">Purchase: Access to Followed Projects Only</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="domain_force">[('work_project_id.message_partner_ids', 'in', [user.partner_id.id])]</field>
        <field name="groups" eval="[Command.link(ref('canas.group_purchase_access_followed_projects'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record model="ir.rule" id="ir_own_documents_project_followers_only_purchase_rule">
        <field name="name">Purchase: Access to Own Documents and Followed Projects</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="domain_force">['&amp;','|', ('create_uid', '=', user.id), ('user_id', '=', user.id), ('work_project_id.message_partner_ids', 'in', [user.partner_id.id])]</field>
        <field name="groups" eval="[Command.link(ref('canas.group_group_purchase_access_own_documents_followed_projects'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record model="ir.rule" id="ir_expense_approver_rule">
        <field name="name">Expense Approver</field>
        <field name="model_id" ref="hr_expense.model_hr_expense"/>
        <field name="domain_force">['|', ('employee_id.user_id.id', '=', user.id), ('employee_id.id', 'in', user.employee_id.expense_approval_employee_ids.ids)]</field>
        <field name="groups" eval="[Command.link(ref('hr_expense.group_hr_expense_team_approver'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record model="ir.rule" id="ir_expense_report_approver_rule">
        <field name="name">Expense Report Approver</field>
        <field name="model_id" ref="hr_expense.model_hr_expense_sheet"/>
        <field name="domain_force">['|', ('employee_id.user_id.id', '=', user.id), ('employee_id.id', 'in', user.employee_id.expense_approval_employee_ids.ids)]</field>
        <field name="groups" eval="[Command.link(ref('hr_expense.group_hr_expense_team_approver'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record model="ir.rule" id="ir_own_expenses_rule">
        <field name="name">Own Expenses</field>
        <field name="model_id" ref="hr_expense.model_hr_expense"/>
        <field name="domain_force">[('employee_id.user_id.id', '=', user.id)]</field>
        <field name="groups" eval="[Command.link(ref('hr_expense.group_hr_expense_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record model="ir.rule" id="ir_own_expense_reports_rule">
        <field name="name">Own Expense Reports</field>
        <field name="model_id" ref="hr_expense.model_hr_expense_sheet"/>
        <field name="domain_force">[('employee_id.user_id.id', '=', user.id)]</field>
        <field name="groups" eval="[Command.link(ref('hr_expense.group_hr_expense_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
