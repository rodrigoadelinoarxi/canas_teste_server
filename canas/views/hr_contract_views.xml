<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
	<record id = "hr_contracts_inherit" model = "ir.ui.view">
		<field name = "name">Hr Contracts Inherit</field>
		<field name = "model">hr.contract</field>
		<field name = "inherit_id" ref = "hr_contract.hr_contract_view_form" />
		<field name = "arch" type = "xml">
			<xpath expr = "//field[@name='structure_type_id']" position = "replace">
				<field name = "structure_type_id_default" string="Default Structure" invisible="1"/>
			</xpath>
			<xpath expr = "//field[@name='structure_type_id_default']" position = "after">
				<field name = "salary_structure" domain="[('type_id', '=', structure_type_id_default)]"/>
			</xpath>
		</field>
	</record>
</odoo>