<odoo>
    <record id="view_fleet_vehicle_form" model="ir.ui.view">
        <field name="name">canas.fleet.vehicle.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='location']" position="after">
                <field name="location_id"/>
            </xpath>
        </field>
    </record>

    <record id='fleet_vehicle_log_services_view_form_inherit' model='ir.ui.view'>
        <field name="name">fleet.vehicle.log.services.view.form.inherit</field>
        <field name="model">fleet.vehicle.log.services</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_log_services_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='service_type_id']" position="before">
                <field name="project_id"/>
            </xpath>
        </field>
    </record>
</odoo>
