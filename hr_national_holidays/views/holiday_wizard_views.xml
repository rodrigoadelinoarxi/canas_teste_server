<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="holiday_wizard_view_form" model="ir.ui.view">
        <field name="name">holiday.wizard.view.form</field>
        <field name="model">holiday.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="calendar_id"/>
                        <field name="year"/>
                    </group>
                </group>
                <footer>
                    <button name="action_get_holidays" string="Confirm" class="btn btn-primary" type="object"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="holiday_wizard_action" model="ir.actions.act_window">
        <field name="name">Import National Holidays</field>
        <field name="res_model">holiday.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
