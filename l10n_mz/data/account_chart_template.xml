<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_mz_chart_template" model="account.chart.template">
        <field name="name">Mozambican Account Chart Template</field>
        <field name="currency_id" ref="base.MZN"/>
        <field name="bank_account_code_prefix">12</field>
        <field name="cash_account_code_prefix">11</field>
        <field name="transfer_account_code_prefix">15</field>
        <field name="code_digits">1</field>
    </record>

    <record id="acc_211" model="account.account.template">
        <field name="code">211</field>
        <field name="name">Mercadorias</field>
        <field name="user_type_id" ref="account.data_account_type_expenses" />
        <field name="chart_template_id" ref="l10n_mz_chart_template"/>
    </record>

    <record id="acc_4111" model="account.account.template">
        <field name="code">4111</field>
        <field name="name">Clientes gerais</field>
        <field name="reconcile" eval="True"/>
        <field name="user_type_id" ref="account.data_account_type_receivable" />
        <field name="chart_template_id" ref="l10n_mz_chart_template"/>
    </record>

    <record id="acc_4211" model="account.account.template">
        <field name="code">4211</field>
        <field name="name">Fornecedores gerais</field>
        <field name="reconcile" eval="True"/>
        <field name="user_type_id" ref="account.data_account_type_payable" />
        <field name="chart_template_id" ref="l10n_mz_chart_template"/>
    </record>

    <record id="acc_694" model="account.account.template">
      <field name="code">694</field>
      <field name="name">Diferenças de câmbio desfavoráveis</field>
      <field name="user_type_id" ref="account.data_account_type_expenses" />
      <field name="chart_template_id" ref="l10n_mz_chart_template"/>
    </record>

    <record id="acc_711" model="account.account.template">
      <field name="code">711</field>
      <field name="name">Mercadoria</field>
      <field name="user_type_id" ref="account.data_account_type_revenue" />
      <field name="chart_template_id" ref="l10n_mz_chart_template"/>
    </record>

    <record id="acc_784" model="account.account.template">
      <field name="code">784</field>
      <field name="name">Diferenças de câmbio favoráveis</field>
      <field name="user_type_id" ref="account.data_account_type_revenue" />
      <field name="chart_template_id" ref="l10n_mz_chart_template"/>
    </record>
</odoo>
